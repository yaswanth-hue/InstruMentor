# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Socket.IO Server URL (for client)
VITE_SOCKET_SERVER_URL=http://localhost:3001

# Backend Server Configuration (for server.js)
PORT=3001

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Load Balancer Settings (if using nginx/haproxy)
# LOAD_BALANCER_URL=http://your-load-balancer:80

# ============================================
# SECURITY SETTINGS
# ============================================

# Node Environment (development | production)
NODE_ENV=development

# Security Keys (CHANGE THESE IN PRODUCTION!)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SSL/TLS (for production)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem

# Trusted Proxies (if behind load balancer)
TRUST_PROXY=true

# Security Headers
HSTS_MAX_AGE=31536000
CSP_ENABLED=true
